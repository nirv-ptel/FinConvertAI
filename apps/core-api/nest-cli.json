{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": ["common/mail/templates/**/*"],
    "watchAssets": true,
    "deleteOutDir": true,
     "plugins": [
          {
            "name": "@nestjs/swagger/plugin",
            "options": {
              "classValidatorShim": true,
              "introspectComments": true
            }
          }
        ]
  }
}
